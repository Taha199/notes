# Vercel serverless environment variables (Project → Settings → Environment Variables)

# Resend API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Sender on verified domain tahanote.com (set after DNS verification in Resend)
RESEND_FROM=Taha Note <noreply@tahanote.com>

# Firebase Admin service account JSON (paste as a single line)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Secret for Vercel Cron → /api/cron/platform-backup (hourly full-app backup to Firebase Storage)
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Resend domain DNS (add in Vercel → Domains → tahanote.com → DNS Records) ---
# Copy exact values from Resend dashboard → Domains → tahanote.com → DNS Records.
# Until all records verify, Resend only delivers to your account owner email.
#
# | Type | Name / Host              | Value (from Resend)                    |
# |------|--------------------------|----------------------------------------|
# | TXT  | resend._domainkey        | p=MIGfMA0GCS... (DKIM — already set)   |
# | TXT  | send                     | v=spf1 include:amazonses.com ~all      |
# | MX   | send                     | feedback-smtp.eu-west-1.amazonses.com  |
#
# After DNS propagates, click Verify in Resend, then redeploy Vercel.
# Vercel project: notes (production at tahanote.com)
